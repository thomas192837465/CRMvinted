# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Récupérer depuis : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici

# Clé service_role — NE JAMAIS exposer côté client
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# ─── OPENAI (pour le module IA de génération de descriptions) ──────────────────
OPENAI_API_KEY=sk-votre_openai_key_ici

# ─── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generez_un_secret_aleatoire_ici

# ─── OPTIONNEL — Analytics ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
